// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
}

model Fornecedor {
  id        String       @id @default(cuid())
  nome      String
  cnpj      String?      @unique
  contato   String?
  email     String?      @unique
  cep       String?
  rua       String?
  bairro    String?
  cidade    String?
  estado    String?
  lotes     LoteEntrada[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Insumo {
  id             String          @id @default(cuid())
  nome           String
  unidade        String          // ex: Unidade, Milheiro, Rolo
  estoqueAtual   Float           @default(0)
  estoqueMinimo  Float           @default(0)
  usoProducao    UsoInsumo[]
  componentesProduto ComponenteProduto[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model LoteEntrada {
  id                String       @id @default(cuid())
  fornecedorId      String
  fornecedor        Fornecedor   @relation(fields: [fornecedorId], references: [id])
  quantidadeOriginal Int         // Quantidade total de ovos recebidos
  dataRecebimento   DateTime     @default(now())
  validadeOriginal  DateTime
  status            LoteStatus   @default(RECEBIDO)
  
  // Triagem
  quantidadeTrincados Int        @default(0)
  quantidadeQuebrados Int        @default(0)
  quantidadeDescarte  Int        @default(0)
  quantidadeAproveitada Int      @default(0) // Calculado: Original - (Trincados + Quebrados + Descarte)
  rendimentoPorcentagem Float    @default(0) // Calculado: (Aproveitada / Original) * 100

  lotesInternos     LoteInterno[]
  financeiro        Financeiro?
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

enum LoteStatus {
  RECEBIDO
  AGUARDANDO_TRIAGEM
  TRIADO
}

model LoteInterno {
  id                String       @id @default(cuid())
  loteEntradaId     String
  loteEntrada       LoteEntrada  @relation(fields: [loteEntradaId], references: [id])
  quantidadeOvos    Int
  dataEmbalagem     DateTime     @default(now())
  validadeSugerida  DateTime     // Calculada com base na validade original
  
  insumosUsados     UsoInsumo[]
  estoqueDisponivel Int
  itensPedido       ItemPedido[]

  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model UsoInsumo {
  id            String      @id @default(cuid())
  insumoId      String
  insumo        Insumo      @relation(fields: [insumoId], references: [id])
  loteInternoId String
  loteInterno   LoteInterno @relation(fields: [loteInternoId], references: [id])
  quantidade    Float

  createdAt     DateTime    @default(now())
}

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  cnpj      String?  @unique
  email     String?  @unique
  cep       String?
  rua       String?
  bairro    String?
  cidade    String?
  estado    String?
  telefone  String?
  contato   String?
  pedidos   Pedido[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pedido {
  id            String       @id @default(cuid())
  clienteId     String
  cliente       Cliente      @relation(fields: [clienteId], references: [id])
  status        PedidoStatus @default(PENDENTE) // PENDENTE, SEPARACAO, ENVIADO, ENTREGUE
  itens         ItemPedido[]
  itensVenda    ItemVenda[]
  financeiro    Financeiro?
  dataPedido    DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model ItemPedido {
  id            String      @id @default(cuid())
  pedidoId      String
  pedido        Pedido      @relation(fields: [pedidoId], references: [id])
  loteInternoId String
  loteInterno   LoteInterno @relation(fields: [loteInternoId], references: [id])
  quantidade    Int         // Quantidade de ovos do lote interno reservados
  
  createdAt     DateTime    @default(now())
}

model Financeiro {
  id            String          @id @default(cuid())
  tipo          FinanceiroTipo  // PAGAR ou RECEBER
  valor         Decimal
  status        FinanceiroStatus @default(PENDENTE)
  dataVencimento DateTime
  dataPagamento DateTime?

  // Relacionamentos opcionais
  loteEntradaId String?         @unique
  loteEntrada   LoteEntrada?    @relation(fields: [loteEntradaId], references: [id])
  pedidoId      String?         @unique
  pedido        Pedido?         @relation(fields: [pedidoId], references: [id])

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

enum PedidoStatus {
  PENDENTE
  SEPARACAO
  ENVIADO
  ENTREGUE
}

enum FinanceiroTipo {
  PAGAR
  RECEBER
}

enum FinanceiroStatus {
  PENDENTE
  PAGO
  CANCELADO
}

enum UserRole {
  DONO
  ADMIN
  OPERADOR
  FINANCEIRO
}

model User {
  id                  String            @id @default(cuid())
  name                String
  email               String            @unique
  password            String
  role                UserRole          @default(ADMIN)
  cpf                 String?
  customPermissionId  String?
  customPermission    CustomPermission? @relation(fields: [customPermissionId], references: [id], onDelete: SetNull)
  active              Boolean           @default(true)
  onboardingDismissed Boolean           @default(false)
  auditLogs           AuditLog[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model CustomPermission {
  id        String   @id @default(cuid())
  nome      String   @unique
  recursos  String   // Armazena JSON dos módulos permitidos, ex: '["dashboard", "logistica"]'
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyProfile {
  id                String   @id @default(cuid())
  razaoSocial       String
  cnpj              String   @unique
  inscricaoEstadual String?
  endereco          String?
  telefone          String?
  email             String?
  logoUrl           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  nome        String   @unique
  ativo       Boolean  @default(true)
  descricao   String?
  valorMensal Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IncomeCategory {
  id          String   @id @default(cuid())
  nome        String   @unique
  ativo       Boolean  @default(true)
  descricao   String?
  valorMensal Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentCondition {
  id        String   @id @default(cuid())
  nome      String   @unique
  dias      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  acao      String
  recurso   String
  createdAt DateTime @default(now())
}

model ItemVenda {
  id                 String   @id @default(cuid())
  pedidoId           String
  pedido             Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  tipoEmbalagem      String   // "6", "12", "15"
  quantidadeBandejas Int
  precoBandeja       Float
  createdAt          DateTime @default(now())
}

model Produto {
  id                String       @id @default(cuid())
  nome              String       // Descrição do produto
  codigo            String       @unique // SKU
  formato           String       // SIMPLES, COMPOSICAO, VARIACOES
  tipo              String       @default("PRODUTO") // Tipo de item
  situacao          Boolean      @default(true) // true = Ativado, false = Desativado
  precoVenda        Decimal      @default(0)
  condicao          String       @default("NOVO") // NOVO, RECONDICIONADO
  imagemUrl         String?
  
  // Características
  marca             String?
  producao          String?      @default("PROPRIA")
  dataValidade      DateTime?
  freteGratis       String?      @default("NAO")
  pesoLiquido       Float?       @default(0)
  pesoBruto         Float?       @default(0)
  largura           Float?       @default(0)
  altura            Float?       @default(0)
  profundidade      Float?       @default(0)
  volumes           Int?         @default(1)
  itensCaixa        Int?         @default(1)
  unidadeMedida     String?      @default("Centimetros")
  gtinEan           String?
  gtinEanTributario String?
  departamento      String?
  
  // Tributação
  origem            String?      @default("0")
  ncm               String?
  cest              String?
  tipoItem          String?      @default("PRODUTO_ACABADO")
  percentualTributos Float?      @default(0)
  grupoProdutos     String?
  icmsBaseStRetencao Float?      @default(0)
  icmsStRetencao    Float?       @default(0)
  icmsProprioSubstituto Float?   @default(0)
  ipiCodigoExcecaoTipi String?
  pisFixo           Float?       @default(0)
  cofinsFixo        Float?       @default(0)
  informacoesAdicionais String?
  
  // Estrutura
  tipoEstoque       String?      @default("VIRTUAL") // VIRTUAL, FISICO
  
  // Relações
  componentes       ComponenteProduto[] @relation("ProdutoPai")
  componenteDe      ComponenteProduto[] @relation("ProdutoFilho")
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model ComponenteProduto {
  id              String   @id @default(cuid())
  produtoPaiId    String
  produtoPai      Produto  @relation("ProdutoPai", fields: [produtoPaiId], references: [id], onDelete: Cascade)
  
  produtoFilhoId  String?
  produtoFilho    Produto? @relation("ProdutoFilho", fields: [produtoFilhoId], references: [id], onDelete: SetNull)
  
  insumoId        String?
  insumo          Insumo?  @relation(fields: [insumoId], references: [id], onDelete: SetNull)
  
  quantidade      Float    @default(1)
  precoCusto      Decimal  @default(0)
  precoVenda      Decimal  @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Funcionario {
  id              String    @id @default(cuid())
  nome            String
  cpf             String    @unique
  rg              String?
  dataNascimento  DateTime?
  fotoUrl         String?
  cargo           String?
  dataAdmissao    DateTime?
  ctps            String?
  salario         Decimal?
  telefone        String?   // Represented as Fone
  celular         String?
  email           String?
  cep             String?
  uf              String?
  cidade          String?
  bairro          String?
  endereco        String?
  numero          String?
  complemento     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

